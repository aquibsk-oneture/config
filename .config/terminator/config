[global_config]
  borderless = True
  window_state = maximise
  focus = mouse
  suppress_multiple_term_warning = True
  title_use_fg_color = False
  title_transmit_fg_color = "#aaaaaa"

[keybindings]
  broadcast_all = <Primary><Alt>b      # Ctrl+Alt+B → broadcast to all
  split_horiz    = <Primary><Shift>o   # Ctrl+Shift+O → horizontal split
  split_vert     = <Primary>e          # Ctrl+E → vertical split
  close_term     = <Primary>w
  new_tab        = <Primary>t
  next_tab       = <Primary>Tab
  prev_tab       = <Primary><Shift>Tab
  zoom_in        = <Primary>plus
  zoom_out       = <Primary>minus
  zoom_normal    = <Primary>0
  hide_window    = <Primary><Alt>grave   # quick hide/show

[profiles]
  [[default]]
    audible_bell = False
    background_darkness = 0.85          # 0.0 = opaque, 1.0 = fully transparent
    background_image = None
    background_type = transparent
    cursor_color = "#eeeeee"
    cursor_shape = ibeam
    font = JetBrains Mono SemiBold 13   # or Fira Code, Cascadia Code, Iosevka, etc.
    foreground_color = "#f8f8f2"
    palette = "#000000:#ff5555:#50fa7b:#f1fa8c:#bd93f9:#ff79c6:#8be9fd:#bbbbbb:#44475a:#ff6e6e:#69ff94:#ffffa5:#d6acff:#ff92df:#a4ffff:#ffffff"
    show_scrollbar = False
    scrollback_lines = 10000
    scroll_on_keystroke = True
    scroll_on_output = False
    use_system_font = False
    use_theme_colors = False
    custom_command = zsh                     # or fish, bash, etc. — change if you want

[layouts]
  [[default]]
    [[[child1]]]
      type = Terminal
      parent = window0
    [[[window0]]]
      type = Window
      parent = ""
